# ATB AgriTrace — Variables d'environnement
# Copier vers .env et remplir les valeurs

# Mode
NODE_ENV=production
API_PORT=4000
API_PUBLIC_URL=https://api.agritrace.bj
CORS_ORIGINS=https://api.agritrace.bj
WEBAPP_URL=https://buyer.agritrace.bj

# PostgreSQL
DB_USER=atb_admin
DB_PASS=change_this_to_random_secret
DB_NAME=atb_agritrace

# JWT
JWT_SECRET=change_this_to_random_secret

# Sentinel Hub (https://dataspace.copernicus.eu)
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_MODE=mock

# FedaPay (https://fedapay.com)
FEDAPAY_API_KEY=
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_SANDBOX=true

# MTN MoMo (https://momodeveloper.mtn.com)
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_SANDBOX=true

# CinetPay (https://cinetpay.com)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SANDBOX=true

# Mansa API (données de marché africain)
MANSA_API_KEY=
MANSA_EMAIL=api@atb.bj
